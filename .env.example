# --- Backend ---
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-32-byte-random-string
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000

# Database (TimescaleDB-flavored Postgres)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=livestream
POSTGRES_PASSWORD=livestream
POSTGRES_DB=livestream_vn
DATABASE_URL=postgresql+asyncpg://livestream:livestream@postgres:5432/livestream_vn

# Redis
REDIS_URL=redis://redis:6379/0

# Object storage (MinIO for dev, S3 in prod)
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=thumbnails
S3_REGION=ap-southeast-1

# AI providers — at least one required for script generation
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_PRIMARY_PROVIDER=anthropic
AI_MODEL_ANTHROPIC=claude-sonnet-4-6
AI_MODEL_OPENAI=gpt-4o

# TikTok Shop integration
TIKTOK_SHOP_APP_KEY=
TIKTOK_SHOP_APP_SECRET=
TIKTOK_WEBHOOK_SECRET=

# Observability
LOG_LEVEL=INFO
SENTRY_DSN=

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000/ws
