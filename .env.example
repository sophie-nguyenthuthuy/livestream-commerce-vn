# --- Backend ---
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-32-byte-random-string
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000

# Database (TimescaleDB-flavored Postgres)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=livestream
POSTGRES_PASSWORD=livestream
POSTGRES_DB=livestream_vn
DATABASE_URL=postgresql+asyncpg://livestream:livestream@postgres:5432/livestream_vn

# Redis
REDIS_URL=redis://redis:6379/0

# Object storage (MinIO for dev, S3 in prod)
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=thumbnails
S3_REGION=ap-southeast-1

# AI — self-hosted OSS LLM via OpenAI-compatible endpoint.
# Default: Ollama on localhost serving Qwen 2.5. For production swap to
# vLLM/SGLang on a GPU node and point LLM_BASE_URL at the gateway.
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=
LLM_MODEL=qwen2.5:7b-instruct
# Production GPU: bump LLM_MODEL to qwen2.5:32b-instruct for richer scripts.
# 7b is OK for dialect templating + objection lines.

# TikTok Shop integration
TIKTOK_SHOP_APP_KEY=
TIKTOK_SHOP_APP_SECRET=
TIKTOK_WEBHOOK_SECRET=

# Observability
LOG_LEVEL=INFO
SENTRY_DSN=

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000/ws
